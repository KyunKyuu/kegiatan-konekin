# ==========================================================================
#  Template environment untuk PRODUCTION (cPanel + MySQL).
#
#  Cara pakai:
#   1. Di server (cPanel File Manager), salin isi file ini menjadi file
#      bernama ".env" di dalam public_html.
#   2. Isi APP_URL, dan kredensial DB_* sesuai database MySQL yang dibuat
#      lewat "MySQL Database Wizard" di cPanel.
#   3. Isi APP_KEY (lihat langkah generate key di DEPLOYMENT.md).
#
#  File ".env" TIDAK ikut ter-commit (di-ignore git) sehingga aman dan
#  tidak akan tertimpa saat deploy berikutnya.
# ==========================================================================

APP_NAME="Jadwal Kegiatan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://domain-anda.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database MySQL (WAJIB diisi) ---
# Nama DB & user di cPanel biasanya berprefix username akun, contoh: "akun_jadwal".
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=akun_jadwal
DB_USERNAME=akun_dbuser
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set ke true HANYA setelah domain sudah aktif HTTPS (AutoSSL). Jika belum,
# biarkan false agar login/session tidak bermasalah di http.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@domain-anda.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
