# ==========================================================================
#  Template environment untuk PRODUCTION (Hostinger hPanel + MySQL).
#
#  Server aktual (daily.konekin.space) SUDAH punya file .env sendiri,
#  dibuat langsung di server dan TIDAK ikut ter-commit ke git (aman dari
#  tertimpa tiap deploy karena GitHub Actions mengecualikan .env saat rsync).
#  File ini murni REFERENSI/CADANGAN kalau perlu setup ulang dari nol.
# ==========================================================================

APP_NAME="Jadwal Kegiatan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://daily.konekin.space

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database MySQL (WAJIB diisi) ---
# Nama DB & user di hPanel biasanya berprefix username akun, contoh: "u385356168_jadwal".
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u385356168_jadwal
DB_USERNAME=u385356168_dbuser
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set ke true HANYA setelah domain sudah aktif HTTPS (AutoSSL). Jika belum,
# biarkan false agar login/session tidak bermasalah di http.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@daily.konekin.space"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
